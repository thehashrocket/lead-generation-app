# App auth — Vercel Authentication handles prod; these are for local dev only
APP_SECRET=                     # Random 32-char hex: openssl rand -hex 16
APP_PASSWORD=                   # Any string; used by the local /login page

# Database (Neon)
DATABASE_URL=                   # Dev: Neon dev branch postgres://user:pass@host/db?sslmode=require
                                # Prod: Neon main branch (set in Vercel dashboard, not .env.local)

# Vercel AI Gateway
# Recommended: run `vercel env pull .env.local` — OIDC token auto-injected, no key needed.
# Fallback only (if not using OIDC): set manually from Vercel Dashboard → AI → Gateways → API Keys
AI_GATEWAY_API_KEY=

# Resend
RESEND_API_KEY=                 # resend.com → API Keys → Create
RESEND_WEBHOOK_SECRET=          # resend.com → Webhooks → Signing Secret
RESEND_FROM_EMAIL=jason@volunteerready.org
RESEND_REPLY_TO_DOMAIN=replies.volunteerready.org

# Hunter.io email finder (optional — feature hidden when absent)
# hunter.io → Dashboard → API → copy key
HUNTER_API_KEY=

# Chrome extension bearer token (generated in app Settings → API Token)
# This is set by the app at runtime — no manual entry here
